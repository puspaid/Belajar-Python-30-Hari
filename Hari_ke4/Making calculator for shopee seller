<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kalkulator Biaya Shopee</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: linear-gradient(135deg, #ee4d2d 0%, #ff6347 100%);
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            color: white;
            margin-bottom: 30px;
        }

        .header h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .header p {
            font-size: 1.1em;
            opacity: 0.95;
        }

        .calculator-card {
            background: white;
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
        }

        .input-group {
            margin-bottom: 25px;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #333;
            font-size: 0.95em;
        }

        .input-group input,
        .input-group select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e0e0e0;
            border-radius: 8px;
            font-size: 1em;
            transition: all 0.3s;
        }

        .input-group input:focus,
        .input-group select:focus {
            outline: none;
            border-color: #ee4d2d;
            box-shadow: 0 0 0 3px rgba(238, 77, 45, 0.1);
        }

        .input-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .btn-calculate {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #ee4d2d 0%, #ff6347 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1.1em;
            font-weight: 600;
            cursor: pointer;
            transition: transform 0.2s, box-shadow 0.2s;
            margin-top: 10px;
        }

        .btn-calculate:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 20px rgba(238, 77, 45, 0.4);
        }

        .btn-calculate:active {
            transform: translateY(0);
        }

        .result-section {
            margin-top: 30px;
            padding-top: 30px;
            border-top: 2px solid #f0f0f0;
        }

        .result-section.hidden {
            display: none;
        }

        .result-card {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }

        .result-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #dee2e6;
        }

        .result-row:last-child {
            border-bottom: none;
        }

        .result-label {
            color: #495057;
            font-size: 0.95em;
        }

        .result-value {
            font-weight: 600;
            color: #212529;
            font-size: 1.05em;
        }

        .profit-section {
            background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
            color: white;
            border-radius: 12px;
            padding: 25px;
            text-align: center;
        }

        .profit-section.negative {
            background: linear-gradient(135deg, #dc3545 0%, #e83e8c 100%);
        }

        .profit-label {
            font-size: 1.1em;
            opacity: 0.9;
            margin-bottom: 10px;
        }

        .profit-value {
            font-size: 2.5em;
            font-weight: 700;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
        }

        .profit-margin {
            font-size: 1.2em;
            margin-top: 10px;
            opacity: 0.95;
        }

        .info-box {
            background: #fff3cd;
            border-left: 4px solid #ffc107;
            padding: 15px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 0.9em;
            color: #856404;
        }

        @media (max-width: 768px) {
            .header h1 {
                font-size: 1.8em;
            }

            .input-row {
                grid-template-columns: 1fr;
            }

            .calculator-card {
                padding: 20px;
            }

            .profit-value {
                font-size: 2em;
            }
        }

        .fee-breakdown {
            background: white;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            padding: 20px;
            margin-top: 15px;
        }

        .fee-breakdown h3 {
            color: #333;
            margin-bottom: 15px;
            font-size: 1.1em;
        }

        .checkbox-group {
            margin-bottom: 20px;
        }

        .checkbox-group label {
            display: flex;
            align-items: center;
            padding: 10px;
            cursor: pointer;
            border-radius: 6px;
            transition: background 0.2s;
        }

        .checkbox-group label:hover {
            background: #f8f9fa;
        }

        .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            margin-right: 10px;
            cursor: pointer;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🛍️ Kalkulator Biaya Shopee</h1>
            <p>Hitung keuntungan bersih dengan akurat</p>
        </div>

        <div class="calculator-card">
            <div class="info-box">
                💡 <strong>Tips:</strong> Masukkan semua biaya untuk menghitung keuntungan bersih yang akurat
            </div>

            <div class="input-group">
                <label>Harga Jual Produk</label>
                <input type="number" id="hargaJual" placeholder="Contoh: 100000" min="0">
            </div>

            <div class="input-group">
                <label>Harga Modal Produk</label>
                <input type="number" id="hargaModal" placeholder="Contoh: 50000" min="0">
            </div>

            <div class="input-row">
                <div class="input-group">
                    <label>Berat Produk (gram)</label>
                    <input type="number" id="berat" placeholder="Contoh: 500" min="0">
                </div>

                <div class="input-group">
                    <label>Jenis Pengiriman</label>
                    <select id="jenisKirim">
                        <option value="reguler">Reguler</option>
                        <option value="instant">Instant/Same Day</option>
                        <option value="cargo">Cargo</option>
                    </select>
                </div>
            </div>

            <div class="input-row">
                <div class="input-group">
                    <label>Biaya Ongkir</label>
                    <input type="number" id="ongkir" placeholder="Contoh: 15000" min="0" value="0">
                </div>

                <div class="input-group">
                    <label>Biaya Packing</label>
                    <input type="number" id="packing" placeholder="Contoh: 5000" min="0" value="0">
                </div>
            </div>

            <div class="checkbox-group">
                <label>
                    <input type="checkbox" id="gratisBiayaAdmin">
                    <span>Gratis Biaya Admin (untuk seller tertentu)</span>
                </label>
            </div>

            <button class="btn-calculate" onclick="calculate()">Hitung Keuntungan</button>

            <div id="resultSection" class="result-section hidden">
                <div class="fee-breakdown">
                    <h3>📊 Rincian Biaya</h3>
                    <div class="result-row">
                        <span class="result-label">Harga Jual</span>
                        <span class="result-value" id="displayHargaJual">Rp 0</span>
                    </div>
                    <div class="result-row">
                        <span class="result-label">Biaya Layanan Shopee (2.5%)</span>
                        <span class="result-value" id="displayBiayaLayanan">Rp 0</span>
                    </div>
                    <div class="result-row">
                        <span class="result-label">Biaya Admin</span>
                        <span class="result-value" id="displayBiayaAdmin">Rp 0</span>
                    </div>
                    <div class="result-row">
                        <span class="result-label">Biaya Ongkir</span>
                        <span class="result-value" id="displayOngkir">Rp 0</span>
                    </div>
                    <div class="result-row">
                        <span class="result-label">Biaya Packing</span>
                        <span class="result-value" id="displayPacking">Rp 0</span>
                    </div>
                    <div class="result-row">
                        <span class="result-label">Modal Produk</span>
                        <span class="result-value" id="displayModal">Rp 0</span>
                    </div>
                    <div class="result-row" style="border-top: 2px solid #dee2e6; padding-top: 15px; margin-top: 10px;">
                        <span class="result-label"><strong>Total Biaya</strong></span>
                        <span class="result-value" id="displayTotalBiaya">Rp 0</span>
                    </div>
                </div>

                <div id="profitSection" class="profit-section">
                    <div class="profit-label">Keuntungan Bersih</div>
                    <div class="profit-value" id="displayProfit">Rp 0</div>
                    <div class="profit-margin" id="displayMargin">Margin: 0%</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function formatRupiah(angka) {
            return 'Rp ' + angka.toLocaleString('id-ID');
        }

        function calculate() {
            const hargaJual = parseFloat(document.getElementById('hargaJual').value) || 0;
            const hargaModal = parseFloat(document.getElementById('hargaModal').value) || 0;
            const berat = parseFloat(document.getElementById('berat').value) || 0;
            const ongkir = parseFloat(document.getElementById('ongkir').value) || 0;
            const packing = parseFloat(document.getElementById('packing').value) || 0;
            const gratisBiayaAdmin = document.getElementById('gratisBiayaAdmin').checked;

            if (hargaJual === 0) {
                alert('Mohon masukkan harga jual produk');
                return;
            }

            // Hitung biaya layanan Shopee (2.5% dari harga jual)
            const biayaLayanan = hargaJual * 0.025;

            // Hitung biaya admin (Rp 1.000 untuk transaksi, gratis jika checkbox dicentang)
            const biayaAdmin = gratisBiayaAdmin ? 0 : 1000;

            // Total biaya
            const totalBiaya = hargaModal + biayaLayanan + biayaAdmin + ongkir + packing;

            // Keuntungan bersih
            const profit = hargaJual - totalBiaya;

            // Margin keuntungan
            const margin = hargaJual > 0 ? (profit / hargaJual * 100) : 0;

            // Update tampilan
            document.getElementById('displayHargaJual').textContent = formatRupiah(hargaJual);
            document.getElementById('displayBiayaLayanan').textContent = formatRupiah(biayaLayanan);
            document.getElementById('displayBiayaAdmin').textContent = gratisBiayaAdmin ? 'Rp 0 (Gratis)' : formatRupiah(biayaAdmin);
            document.getElementById('displayOngkir').textContent = formatRupiah(ongkir);
            document.getElementById('displayPacking').textContent = formatRupiah(packing);
            document.getElementById('displayModal').textContent = formatRupiah(hargaModal);
            document.getElementById('displayTotalBiaya').textContent = formatRupiah(totalBiaya);
            document.getElementById('displayProfit').textContent = formatRupiah(profit);
            document.getElementById('displayMargin').textContent = `Margin: ${margin.toFixed(2)}%`;

            // Update warna profit section
            const profitSection = document.getElementById('profitSection');
            if (profit < 0) {
                profitSection.classList.add('negative');
            } else {
                profitSection.classList.remove('negative');
            }

            // Tampilkan hasil
            document.getElementById('resultSection').classList.remove('hidden');

            // Scroll ke hasil
            document.getElementById('resultSection').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // Allow Enter key to calculate
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('input[type="number"]');
            inputs.forEach(input => {
                input.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        calculate();
                    }
                });
            });
        });
    </script>
</body>
</html>
